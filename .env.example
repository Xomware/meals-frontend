# Meals API (DynamoDB via API Gateway)
NEXT_PUBLIC_API_URL=https://api.xomappetit.xomware.com

# Cognito (Phase 2 cutover — replaces NEXT_PUBLIC_AUTH_HASH)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=xomware-auth.auth.us-east-1.amazoncookie.com
